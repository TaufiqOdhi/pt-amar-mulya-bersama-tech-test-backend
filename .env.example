PORT=8080
APP_ENV=development

# Database configuration (use 'db' when running inside container, or 'localhost' when running outside)
DATABASE_URL=postgres://postgres:postgres@db:5432/todo_db?sslmode=disable

# Redis configuration (use 'redis' when running inside container, or 'localhost' when running outside)
REDIS_URL=redis://redis:6379

# JWT Secret & Expiry
JWT_SECRET=super-secret-jwt-key-change-in-production
JWT_EXPIRATION_HOURS=24
